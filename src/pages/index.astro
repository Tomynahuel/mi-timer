---
// Aquí definimos la fecha objetivo en el frontmatter de Astro
const BODA_INFO = {
  fechaCuentaRegresiva: "2026-12-31T23:59:59" // <-- CAMBIA ESTO POR TU FECHA
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Cuenta Regresiva</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="marco-exterior">
      <div class="contenedor-principal">
        
        <h1>¡EL GRAN DÍA!</h1>
        <p class="subtitulo">KEEP CALM AND FOCUS</p>

        <div id="countdown" class="reloj-digital">
          <div class="bloque-tiempo">
            <span data-unit="days">00</span>
            <span class="etiqueta">DÍAS</span>
          </div>
          <span class="separador">:</span>
          <div class="bloque-tiempo">
            <span data-unit="hours">00</span>
            <span class="etiqueta">HRS</span>
          </div>
          <span class="separador">:</span>
          <div class="bloque-tiempo">
            <span data-unit="minutes">00</span>
            <span class="etiqueta">MIN</span>
          </div>
          <span class="separador">:</span>
          <div class="bloque-tiempo">
            <span data-unit="seconds">00</span>
            <span class="etiqueta">SEG</span>
          </div>
        </div>

        <div class="contenedor-barra">
          <div class="barra-verde"></div>
        </div>
        <div class="texto-porcentaje">LOADING...</div>

      </div>
    </div>

    <script define:vars={{ fechaMagica: BODA_INFO.fechaCuentaRegresiva }}>
      const targetTime = new Date(fechaMagica).getTime();
      const container = document.getElementById('countdown');

      if (container) {
        setInterval(() => {
          const now = Date.now();
          const d = targetTime - now;
          if (d < 0) return;

          const days = Math.floor(d / (1000 * 60 * 60 * 24));
          const hours = Math.floor((d / (1000 * 60 * 60)) % 24);
          const minutes = Math.floor((d / (1000 * 60)) % 60);
          const seconds = Math.floor((d / 1000) % 60);

          container.querySelector('[data-unit="days"]').textContent = days.toString().padStart(2, '0');
          container.querySelector('[data-unit="hours"]').textContent = hours.toString().padStart(2, '0');
          container.querySelector('[data-unit="minutes"]').textContent = minutes.toString().padStart(2, '0');
          container.querySelector('[data-unit="seconds"]').textContent = seconds.toString().padStart(2, '0');
        }, 1000);
      }
    </script>

    <style>
      /* Estilos globales */
      body {
        margin: 0;
        padding: 0;
        background-color: #0a0a0a; /* Fondo oscuro */
        color: #f0f0f0;
        font-family: 'VT323', monospace; /* Fuente digital */
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
      }

      /* Borde exterior gris sutil de la imagen */
      .marco-exterior {
        border: 2px solid #333;
        padding: 4px;
        width: 90%;
        max-width: 800px;
      }

      .contenedor-principal {
        border: 1px solid #444;
        padding: 3rem;
        text-align: center;
        background-color: #050505;
      }

      h1 {
        font-size: 4rem;
        margin: 0;
        letter-spacing: 4px;
        font-weight: normal;
      }

      .subtitulo {
        color: #7bb5e3; /* Color celeste de la imagen */
        font-size: 1.5rem;
        margin-top: 0.2rem;
        margin-bottom: 4rem;
        letter-spacing: 2px;
      }

      /* Estilos del Reloj */
      .reloj-digital {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        font-size: 6rem; /* Tamaño grande para los números */
        margin-bottom: 3rem;
      }

      .bloque-tiempo {
        display: flex;
        flex-direction: column;
        align-items: center;
        line-height: 0.8;
      }

      .etiqueta {
        font-size: 1.2rem;
        color: #666;
        margin-top: 1rem;
        letter-spacing: 2px;
      }

      .separador {
        margin: 0 1rem;
        position: relative;
        top: -10px;
      }

      /* Barra de Progreso */
      .contenedor-barra {
        width: 100%;
        height: 45px;
        background-color: #6c7576; /* Gris de la parte vacía */
        margin-bottom: 0.5rem;
      }

      .barra-verde {
        height: 100%;
        width: 47%; /* Representación fija para emular la imagen */
        background-color: #65a11c; /* Verde del progreso */
      }

      .texto-porcentaje {
        color: #7bb5e3;
        font-size: 1.2rem;
      }
    </style>
  </body>
</html>